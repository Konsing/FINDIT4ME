# Upstash Redis (caching scraped results)
# Get from: https://upstash.com or Vercel Marketplace
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# eBay Browse API
# Get from: https://developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Google Custom Search
# Get from: https://console.cloud.google.com + https://programmablesearchengine.google.com
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Shopify stores to scrape (comma-separated domains)
SHOPIFY_STORES=store.adhocla.com
