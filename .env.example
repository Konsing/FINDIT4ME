# Upstash Redis (caching scraped results)
# Get from: https://upstash.com or Vercel Marketplace
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# eBay Browse API
# Get from: https://developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# SerpAPI (Google Shopping search results — 100 free searches/month)
# Get from: https://serpapi.com/manage-api-key
SERPAPI_KEY=

# Shopify stores to scrape (comma-separated domains)
SHOPIFY_STORES=store.adhocla.com
